---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout
  title="Terms and Conditions - Share Text Pad"
  description="Review the terms and conditions for using Share Text Pad and its collaborative note sharing services."
>
  <div class="min-h-screen overflow-x-hidden">
    <Navbar />
    <main id="main-content" class="mx-auto w-full max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
      <section class="rounded-2xl border border-zinc-200 bg-white/85 p-6 text-zinc-700 shadow-[0_24px_80px_-52px_rgba(0,0,0,0.55)] dark:border-zinc-800 dark:bg-zinc-900/85 dark:text-zinc-300 sm:p-8">
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-950 dark:text-zinc-100">Terms & Conditions</h1>
        <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400">Last updated: July 10, 2026</p>

        <div class="mt-6 space-y-5 text-sm leading-7 sm:text-base">
          <div>
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">1. Acceptance of Terms</h2>
            <p class="mt-2">
              By using Share Text Pad, you agree to these terms and applicable laws. If you do not agree, do not use the service.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">2. Permitted Use</h2>
            <p class="mt-2">
              You may use Share Text Pad for lawful collaboration and note sharing. You must not use the platform for harmful,
              abusive, illegal, or unauthorized activities.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">3. Content Responsibility</h2>
            <p class="mt-2">
              You are responsible for content you create or share through the platform. Ensure you have the rights to publish
              that content.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">4. Service Availability</h2>
            <p class="mt-2">
              We may update, suspend, or discontinue parts of the service at any time. We aim for reliability but do not warrant
              uninterrupted availability.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">5. Limitation of Liability</h2>
            <p class="mt-2">
              Share Text Pad is provided "as is" without warranties to the maximum extent permitted by law. We are not liable for
              indirect or consequential damages arising from service use.
            </p>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</Layout>
