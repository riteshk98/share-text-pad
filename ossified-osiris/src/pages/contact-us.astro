---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout
  title="Contact Us - Share Text Pad"
  description="Contact Share Text Pad for support, product questions, or partnership inquiries."
>
  <div class="min-h-screen overflow-x-hidden">
    <Navbar />
    <main id="main-content" class="mx-auto w-full max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
      <section class="rounded-2xl border border-zinc-200 bg-white/85 p-6 text-zinc-700 shadow-[0_24px_80px_-52px_rgba(0,0,0,0.55)] dark:border-zinc-800 dark:bg-zinc-900/85 dark:text-zinc-300 sm:p-8">
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-950 dark:text-zinc-100">Contact Us</h1>
        <p class="mt-4 text-sm leading-7 sm:text-base">
          Need help with Share Text Pad, have feedback, or want to discuss partnerships? We would love to hear from you.
        </p>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-950/70">
            <p class="text-xs uppercase tracking-[0.11em] text-zinc-500 dark:text-zinc-400">Support</p>
            <p class="mt-2 text-sm font-medium text-zinc-900 dark:text-zinc-100">
              <a class="underline decoration-zinc-300 underline-offset-2 hover:text-zinc-700 dark:decoration-zinc-700 dark:hover:text-zinc-200" href="mailto:support@sharetextpad.app">support@sharetextpad.app</a>
            </p>
          </div>
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-950/70">
            <p class="text-xs uppercase tracking-[0.11em] text-zinc-500 dark:text-zinc-400">General</p>
            <p class="mt-2 text-sm font-medium text-zinc-900 dark:text-zinc-100">
              <a class="underline decoration-zinc-300 underline-offset-2 hover:text-zinc-700 dark:decoration-zinc-700 dark:hover:text-zinc-200" href="mailto:hello@sharetextpad.app">hello@sharetextpad.app</a>
            </p>
          </div>
        </div>

        <p class="mt-6 text-xs text-zinc-500 dark:text-zinc-400">
          We typically respond within 1-2 business days.
        </p>
      </section>
    </main>
    <SiteFooter />
  </div>
</Layout>
