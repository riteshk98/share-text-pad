---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { DocumentShareModal } from '../../components/DocumentShareModal';
import { CollaborativeEditor } from '../../components/editor/CollaborativeEditor';
import { NamePromptModal } from '../../components/NamePromptModal';

export const prerender = false;

const { id } = Astro.params;

if (!id || !/^[A-Za-z0-9]{4,32}$/.test(id)) {
  return Astro.redirect('/');
}
---

<Layout
  title={`Note ${id} - Share Text Pad`}
  description="Collaborative note editor connected to Fastify document APIs."
>
  <div class="min-h-screen overflow-x-hidden">
    <Navbar />
    <NamePromptModal client:load />
    <main id="main-content" class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3 rounded-xl border border-zinc-200 bg-white/70 px-4 py-3 text-sm text-zinc-600 dark:border-zinc-800 dark:bg-zinc-900/70 dark:text-zinc-400">
        <p>Share URL:</p>
        <code class="rounded bg-zinc-100 px-2 py-1 font-mono text-xs text-zinc-800 dark:bg-zinc-800 dark:text-zinc-200">/notes/{id}</code>
        <DocumentShareModal client:load noteId={id} />
      </div>

      <CollaborativeEditor client:load noteId={id} />
    </main>
  </div>
</Layout>
