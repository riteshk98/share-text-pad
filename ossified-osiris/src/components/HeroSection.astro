---
import Button from './ui/Button.astro';
import { CreateNoteButton } from './CreateNoteButton';
---

<section class="relative overflow-hidden px-4 pb-20 pt-14 sm:px-6 lg:px-8 lg:pt-20">
  <div class="hero-mesh pointer-events-none absolute left-1/2 top-[-20rem] -z-10 h-[32rem] w-[62rem] -translate-x-1/2 rounded-full blur-3xl"></div>

  <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-2 lg:items-center">
    <div class="space-y-8 reveal-up">
      <p class="inline-flex rounded-full border border-zinc-300/80 bg-white/80 px-3 py-1 text-xs font-medium uppercase tracking-[0.12em] text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900/75 dark:text-zinc-300">
        Real-Time Collaborative Notepad
      </p>
      <h1 class="text-balance text-4xl font-semibold tracking-[-0.04em] text-zinc-950 sm:text-5xl lg:text-6xl dark:text-zinc-100">
        Write Together, Share Instantly, Finish Faster
      </h1>
      <p class="max-w-xl text-balance text-lg leading-8 text-zinc-600 dark:text-zinc-400">
        Share Text Pad makes live editing feel effortless. Open a note, invite people with a link or QR, and watch every cursor update in real time.
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <CreateNoteButton client:load />
        <Button size="lg" variant="secondary" href="#features">Explore Features</Button>
      </div>

      <ul class="grid gap-3 text-sm text-zinc-600 sm:grid-cols-2 dark:text-zinc-400">
        <li class="rounded-xl border border-zinc-200/70 bg-white/70 p-3 dark:border-zinc-800 dark:bg-zinc-900/70">No sign-up required for collaboration</li>
        <li class="rounded-xl border border-zinc-200/70 bg-white/70 p-3 dark:border-zinc-800 dark:bg-zinc-900/70">Secure link-based sharing with role hints</li>
      </ul>
    </div>

    <div class="reveal-up [animation-delay:120ms]">
      <div class="relative overflow-hidden rounded-3xl border border-zinc-200/70 bg-white/90 p-4 shadow-[0_26px_80px_-46px_rgba(0,0,0,0.55)] dark:border-zinc-700/80 dark:bg-zinc-900/90">
        <div class="absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-sky-500/60 to-transparent"></div>

        <div class="rounded-2xl border border-zinc-200 bg-zinc-50 px-4 py-3 dark:border-zinc-700 dark:bg-zinc-950">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-[11px] uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400">Shared Note</p>
              <p class="text-sm font-semibold text-zinc-800 dark:text-zinc-200">Weekly launch plan</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/15 px-2.5 py-1 text-xs font-medium text-emerald-700 dark:text-emerald-300">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
              Live collaboration
            </span>
          </div>
          <p class="mt-2 text-xs text-zinc-600 dark:text-zinc-400">Link sharing: /notes/weekly-launch-plan</p>
        </div>

        <div class="mt-4 rounded-2xl border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-950/80">
          <div class="flex flex-wrap items-center gap-2 border-b border-zinc-200 px-3 py-2 dark:border-zinc-800">
            <span class="rounded-md border border-zinc-300 px-2 py-0.5 text-xs text-zinc-700 dark:border-zinc-700 dark:text-zinc-300">Bold</span>
            <span class="rounded-md border border-zinc-300 px-2 py-0.5 text-xs text-zinc-700 dark:border-zinc-700 dark:text-zinc-300">H1</span>
            <span class="rounded-md border border-zinc-300 px-2 py-0.5 text-xs text-zinc-700 dark:border-zinc-700 dark:text-zinc-300">Bullet List</span>
            <span class="rounded-md border border-zinc-300 px-2 py-0.5 text-xs text-zinc-700 dark:border-zinc-700 dark:text-zinc-300">Code</span>
          </div>

          <div class="space-y-2 p-4 text-sm text-zinc-700 dark:text-zinc-300">
            <p class="text-zinc-900 dark:text-zinc-100"><span class="font-semibold">H1:</span> Launch checklist</p>
            <p>• Publish release notes and update docs</p>
            <p>• Share note link with QA and content team</p>
            <p>• Track edits in real time during standup</p>
            <p class="rounded-md bg-zinc-100 px-2 py-1 font-mono text-xs text-zinc-700 dark:bg-zinc-900 dark:text-zinc-300">const shareMode = 'qr-or-link';</p>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-3">
          <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-950/70">
            <p class="text-xs uppercase tracking-[0.11em] text-zinc-500 dark:text-zinc-400">Online users</p>
            <div class="mt-2 flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-sky-500"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-fuchsia-500"></span>
              <span class="text-sm font-semibold text-zinc-800 dark:text-zinc-200">3 active</span>
            </div>
          </div>
          <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-950/70">
            <p class="text-xs uppercase tracking-[0.11em] text-zinc-500 dark:text-zinc-400">Version history</p>
            <p class="mt-2 text-sm font-semibold text-zinc-800 dark:text-zinc-200">Snapshots available</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
