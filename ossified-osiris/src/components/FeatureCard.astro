---
interface Props {
  title: string;
  description: string;
  icon: string;
  badge?: string;
  featured?: boolean;
}

const {
  title,
  description,
  icon,
  badge,
  featured = false,
} = Astro.props as Props;
---

<article
  class:list={[
    'group relative overflow-hidden rounded-2xl border p-6 backdrop-blur-sm transition-transform duration-300 motion-reduce:transition-none motion-safe:hover:-translate-y-0.5',
    featured
      ? 'border-zinc-200/80 bg-white/90 shadow-[0_24px_64px_-48px_rgba(0,0,0,0.45)] dark:border-zinc-700/80 dark:bg-zinc-900/90'
      : 'border-zinc-200/70 bg-white/75 dark:border-zinc-800 dark:bg-zinc-900/70',
  ]}
>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sky-500/60 to-transparent"></div>
  <div class="flex items-center justify-between gap-3">
    <span class="text-2xl" aria-hidden="true">{icon}</span>
    {badge && (
      <span class="rounded-full border border-zinc-300/80 px-2.5 py-1 text-[11px] font-medium uppercase tracking-[0.12em] text-zinc-600 dark:border-zinc-700 dark:text-zinc-400">
        {badge}
      </span>
    )}
  </div>
  <h3 class="mt-4 text-xl font-semibold tracking-tight text-zinc-950 dark:text-zinc-100">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400">{description}</p>
</article>
